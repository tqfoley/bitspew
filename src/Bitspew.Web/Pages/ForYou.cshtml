@page
@model Bitspew.Web.Pages.ForYouModel
@{
    ViewData["Title"] = "For you";
}

<h1 class="h3 mb-3">For you</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" class="mb-4">
    <div class="mb-2">
        <label class="form-label" for="body">What's happening?</label>
        <textarea class="form-control" id="body" asp-for="Body" rows="3" maxlength="10000" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Post</button>
</form>

@if (Model.Messages.Count == 0)
{
    <p class="text-muted">No messages yet — be the first to post.</p>
}
else
{
    foreach (var message in Model.Messages)
    {
        <div class="card mb-2">
            <div class="card-body py-2">
                <div class="text-muted small">@message.CreatedAt.ToString("u")</div>
                <div style="white-space: pre-wrap">@message.Body</div>
            </div>
        </div>
    }
}
