@page
@model Bitspew.Web.Pages.SignMessageModel
@{
    ViewData["Title"] = "Sign a message";
}

<h1 class="h3 mb-3">Sign a message</h1>

<div class="alert alert-info">
    Signing happens <strong>entirely in your browser</strong> — this page has no form submission
    and your private key is never sent to the server. Even so, pasting a key into any web page
    carries risk: prefer signing in your own wallet for keys that hold real funds, and use a
    dedicated posting key here.
</div>

<div class="mb-3">
    <label class="form-label" for="private-key">Private key (WIF or 64-char hex)</label>
    <div class="input-group">
        <input class="form-control font-monospace" id="private-key" type="password"
               autocomplete="off" spellcheck="false" placeholder="K..., L..., 5..., or hex" />
        <button class="btn btn-outline-secondary" type="button" id="toggle-key">Show</button>
        <button class="btn btn-outline-primary" type="button" id="generate-key">Generate new key</button>
    </div>
    <div class="form-text" id="key-status">Loading signing module&hellip;</div>
</div>

<div class="mb-3">
    <label class="form-label" for="message">Message to sign</label>
    <textarea class="form-control font-monospace" id="message" rows="7"
              placeholder="Paste the exact text to sign — e.g. the payload from the New thread page."></textarea>
</div>

<button class="btn btn-primary" type="button" id="sign-button">Sign message</button>

<div id="error" class="alert alert-danger mt-3 d-none"></div>

<div id="results" class="mt-4 d-none">
    <div class="mb-3">
        <label class="form-label" for="public-key">Public key (hex)</label>
        <div class="input-group">
            <input class="form-control font-monospace" id="public-key" readonly />
            <button class="btn btn-outline-secondary copy-btn" type="button" data-copy="public-key">Copy</button>
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label" for="address">Address (P2PKH)</label>
        <div class="input-group">
            <input class="form-control font-monospace" id="address" readonly />
            <button class="btn btn-outline-secondary copy-btn" type="button" data-copy="address">Copy</button>
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label" for="signature">Signature (base64) — paste this into the publish form</label>
        <div class="input-group">
            <input class="form-control font-monospace" id="signature" readonly />
            <button class="btn btn-outline-secondary copy-btn" type="button" data-copy="signature">Copy</button>
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label" for="signed-block">Complete signed message</label>
        <textarea class="form-control font-monospace" id="signed-block" rows="9" readonly></textarea>
        <button class="btn btn-outline-secondary btn-sm mt-2 copy-btn" type="button" data-copy="signed-block">Copy signed message</button>
    </div>
</div>

@section Scripts {
    @* Relative src survives reverse proxies that add/strip a path prefix; data-cfasync
       opts out of Cloudflare Rocket Loader, which breaks rewritten scripts. Bump ?v=
       when this file changes so proxy caches cannot serve a stale copy. *@
    <script data-cfasync="false" src="js/bitcoin-sign.js?v=4"></script>
    <script data-cfasync="false">
        // Plain script so Show/Hide works even if the signing script fails to load.
        (function () {
            var toggle = document.getElementById('toggle-key');
            var input = document.getElementById('private-key');
            toggle.addEventListener('click', function () {
                var hidden = input.type === 'password';
                input.type = hidden ? 'text' : 'password';
                toggle.textContent = hidden ? 'Hide' : 'Show';
            });
            window.addEventListener('error', function (e) {
                var status = document.getElementById('key-status');
                if (status && e.message) status.textContent = 'Script error: ' + e.message;
            });
        })();
    </script>
    <script data-cfasync="false">
        const el = id => document.getElementById(id);

        console.log('[sign-page] environment:', {
            url: location.href,
            isSecureContext: window.isSecureContext,
            hasSubtleCrypto: !!(window.crypto && window.crypto.subtle),
            bitcoinSignLoaded: !!window.bitcoinSign,
            bitcoinSignVersion: window.bitcoinSign && window.bitcoinSign.version,
            scriptUrl: new URL('js/bitcoin-sign.js?v=4', location.href).href,
        });

        if (!window.bitcoinSign) {
            el('key-status').textContent =
                'Signing script failed to load from ' + new URL('js/bitcoin-sign.js', location.href) +
                ' — if this site is behind Cloudflare, purge its cache and disable Rocket Loader.';
            throw new Error('bitcoin-sign.js did not load');
        }
        const { signBitcoinMessage, derivePublicKey, generatePrivateKey } = window.bitcoinSign;
        const READY_HINT = 'Ready. Paste a private key, or click "Generate new key".';
        const showError = text => {
            el('error').textContent = text;
            el('error').classList.toggle('d-none', !text);
        };

        async function copyText(text) {
            if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(text);
                return;
            }
            // http:// pages have no clipboard API; fall back to the legacy path
            const scratch = document.createElement('textarea');
            scratch.value = text;
            scratch.style.position = 'fixed';
            scratch.style.opacity = '0';
            document.body.appendChild(scratch);
            scratch.select();
            document.execCommand('copy');
            document.body.removeChild(scratch);
        }

        el('private-key').addEventListener('input', async () => {
            const value = el('private-key').value.trim();
            if (!value) { el('key-status').textContent = READY_HINT; return; }
            try {
                const info = await derivePublicKey(value);
                el('key-status').textContent =
                    `Address ${info.address} (${info.compressed ? 'compressed' : 'uncompressed'} key)`;
            } catch (e) {
                el('key-status').textContent = e.message;
            }
        });

        el('generate-key').addEventListener('click', async () => {
            console.log('[sign-page] generate-key clicked');
            showError('');
            try {
                const keyInfo = await generatePrivateKey();
                const input = el('private-key');
                input.value = keyInfo.wif;
                input.type = 'text';
                el('toggle-key').textContent = 'Hide';
                el('key-status').textContent =
                    `New key generated — save it somewhere safe, it exists only on this page. Address ${keyInfo.address}`;
            } catch (e) {
                showError(e.message);
            }
        });

        el('sign-button').addEventListener('click', async () => {
            console.log('[sign-page] sign-button clicked');
            showError('');
            el('results').classList.add('d-none');
            try {
                const key = el('private-key').value;
                const message = el('message').value;
                if (!key.trim()) throw new Error('Enter a private key, or click "Generate new key".');
                if (!message) throw new Error('Enter a message to sign.');
                const result = await signBitcoinMessage(key, message);
                el('public-key').value = result.publicKeyHex;
                el('address').value = result.address;
                el('signature').value = result.signature;
                el('signed-block').value = result.signedBlock;
                el('results').classList.remove('d-none');
            } catch (e) {
                console.log('[sign-page] signing failed:', e);
                showError(e.message);
            }
        });

        for (const button of document.querySelectorAll('.copy-btn')) {
            button.addEventListener('click', async () => {
                await copyText(el(button.dataset.copy).value);
                const label = button.textContent;
                button.textContent = 'Copied!';
                setTimeout(() => button.textContent = label, 1200);
            });
        }

        el('key-status').textContent = READY_HINT;
        console.log('[sign-page] handlers attached, page ready');
    </script>
}
