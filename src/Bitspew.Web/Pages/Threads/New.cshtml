@page "/new"
@model Bitspew.Web.Pages.Threads.NewModel
@{
    ViewData["Title"] = "New thread";
}

<h1 class="h3 mb-3">Start a thread</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.PayloadToSign is null)
{
    <form method="post" asp-page-handler="Prepare">
        <div class="mb-3">
            <label class="form-label" for="title">Title</label>
            <input class="form-control" id="title" asp-for="Title" maxlength="200" required />
        </div>
        <div class="mb-3">
            <label class="form-label" for="address">Your Bitcoin address</label>
            <input class="form-control font-monospace" id="address" asp-for="Address" required
                   placeholder="1..., 3..., or bc1q..." />
        </div>
        <div class="mb-3">
            <label class="form-label" for="body">Message</label>
            <textarea class="form-control" id="body" asp-for="Body" rows="6" maxlength="10000" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Next: get text to sign</button>
    </form>
}
else
{
    <p>
        Sign this exact text with the key for <code>@Model.Address</code>
        (Electrum: Tools &rarr; Sign/Verify Message; Bitcoin Core: <code>signmessage</code>),
        then paste the base64 signature below. The timestamp expires after 15 minutes.
    </p>
    <div class="mb-3">
        <textarea class="form-control font-monospace" id="payload" rows="8" readonly>@Model.PayloadToSign</textarea>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                onclick="navigator.clipboard.writeText(document.getElementById('payload').value)">
            Copy to clipboard
        </button>
    </div>
    <form method="post" asp-page-handler="Publish">
        <input type="hidden" asp-for="Title" />
        <input type="hidden" asp-for="Address" />
        <input type="hidden" asp-for="Body" />
        <input type="hidden" asp-for="SignedAtUnixSeconds" />
        <div class="mb-3">
            <label class="form-label" for="signature">Signature (base64)</label>
            <input class="form-control font-monospace" id="signature" asp-for="Signature" required />
        </div>
        <button type="submit" class="btn btn-primary">Publish thread</button>
        <a class="btn btn-link" asp-page="/Threads/New">Start over</a>
    </form>
}
