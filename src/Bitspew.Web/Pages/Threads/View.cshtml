@page "/t/{id}"
@model Bitspew.Web.Pages.Threads.ViewThreadModel
@{
    ViewData["Title"] = Model.Thread?.Title ?? "Thread";
}

<h1 class="h3 mb-1">@Model.Thread!.Title</h1>
<p class="text-muted small">
    Thread <code title="@Model.Thread.Id">@Model.Thread.Id[..16]…</code>
    started by <code>@Model.Thread.Address</code>
</p>

@foreach (var item in Model.Posts)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><code>@item.Post.Address</code></span>
            <span>
                @if (item.Verified)
                {
                    <span class="badge bg-success" title="The stored signature verifies against the address.">signature verified</span>
                }
                else
                {
                    <span class="badge bg-danger" title="The stored signature does NOT verify. This post may have been tampered with.">verification failed</span>
                }
                <small class="text-muted ms-2">
                    signed @DateTimeOffset.FromUnixTimeSeconds(item.Post.SignedAtUnixSeconds).ToString("yyyy-MM-dd HH:mm") UTC
                </small>
            </span>
        </div>
        <div class="card-body">
            <p class="card-text" style="white-space: pre-wrap">@item.Post.Body</p>
        </div>
        <div class="card-footer text-muted small">
            post id <code title="@item.Post.Id">@item.Post.Id[..16]…</code>
        </div>
    </div>
}

<h2 class="h5 mt-4">Reply</h2>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.PayloadToSign is null)
{
    <form method="post" asp-page-handler="Prepare">
        <div class="mb-3">
            <label class="form-label" for="address">Your Bitcoin address</label>
            <input class="form-control font-monospace" id="address" asp-for="Address" required
                   placeholder="1..., 3..., or bc1q..." />
        </div>
        <div class="mb-3">
            <label class="form-label" for="body">Message</label>
            <textarea class="form-control" id="body" asp-for="Body" rows="4" maxlength="10000" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Next: get text to sign</button>
    </form>
}
else
{
    <p>
        Sign this exact text with the key for <code>@Model.Address</code>, then paste the
        base64 signature below. The timestamp expires after 15 minutes.
    </p>
    <div class="mb-3">
        <textarea class="form-control font-monospace" id="payload" rows="7" readonly>@Model.PayloadToSign</textarea>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                onclick="navigator.clipboard.writeText(document.getElementById('payload').value)">
            Copy to clipboard
        </button>
    </div>
    <form method="post" asp-page-handler="Publish">
        <input type="hidden" asp-for="Address" />
        <input type="hidden" asp-for="Body" />
        <input type="hidden" asp-for="SignedAtUnixSeconds" />
        <div class="mb-3">
            <label class="form-label" for="signature">Signature (base64)</label>
            <input class="form-control font-monospace" id="signature" asp-for="Signature" required />
        </div>
        <button type="submit" class="btn btn-primary">Publish reply</button>
        <a class="btn btn-link" href="/t/@Model.Thread.Id">Cancel</a>
    </form>
}
